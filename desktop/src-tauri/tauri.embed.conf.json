{
  "productName": "bfe-tools",
  "version": "0.1.0",
  "identifier": "com.bfe.tools",
  "build": {
    "frontendDist": "/Users/zhangtao/Documents/study/bfe-tools/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir /Users/zhangtao/Documents/study/bfe-tools/web dev",
    "beforeBuildCommand": "pnpm --dir /Users/zhangtao/Documents/study/bfe-tools/web build"
  },
  "app": {
    "security": { "csp": "default-src 'self' http://127.0.0.1:*; connect-src 'self' http://127.0.0.1:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:" },
    "windows": [
      {
        "title": "bfe-tools",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": { "minimumSystemVersion": "11.0" },
    "windows": { "wix": { "language": "zh-CN" } }
  }
}
