{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "paths": {
      "@/*": ["./src/*"]
    },
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["env.d.ts", "src/**/*.ts", "src/**/*.vue"]
}
