# 构建产物
dist/
dist-ssr/
*.local

# TypeScript 构建缓存
*.tsbuildinfo

# 禁止 src 下的 .js 编译缓存（Vite 会优先加载 .js 而非 .ts 源码）
src/**/*.js
!src/**/*.test.js

# 依赖
node_modules/

# Editor / IDE
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# Environment variables
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
